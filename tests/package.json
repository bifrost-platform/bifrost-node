{
  "name": "@bifrost-platform/bifrost-node",
  "version": "2.1.1",
  "author": "bifrost-platform",
  "type": "module",
  "scripts": {
    "test": "tsx ./node_modules/.bin/mocha tests/**/**/*.ts --exit",
    "clean_test": "rm -rf node_modules && npm install && npm test",
    "test_local_runtime": "tsx ./node_modules/.bin/mocha runtime/**/**/*local_runtime*.ts --exit",
    "test_live_runtime": "tsx ./node_modules/.bin/mocha runtime/**/**/*live_runtime*.ts --exit",
    "run_node": "NODE_OPTIONS='--import=tsx/esm' tsx commands/run_node.ts",
    "set_node": "NODE_OPTIONS='--import=tsx/esm' tsx commands/set_node.ts",
    "rewind_node": "NODE_OPTIONS='--import=tsx/esm' tsx commands/rewind_node.ts",
    "purge_chains": "NODE_OPTIONS='--import=tsx/esm' tsx commands/purge_chains.ts",
    "purge_containers": "NODE_OPTIONS='--import=tsx/esm' tsx commands/purge_containers.ts",
    "benchmark": "NODE_OPTIONS='--import=tsx/esm --no-warnings' tsx benchmark/index.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bifrost-platform/bifrost-node.git"
  },
  "dependencies": {
    "@polkadot/api": "16.5.4",
    "axios": "1.13.6",
    "bignumber.js": "10.0.2",
    "ethers": "6.16.0",
    "shelljs": "0.10.0",
    "tcp-port-used": "1.0.2",
    "tsx": "4.21.0",
    "web3": "4.16.0"
  },
  "devDependencies": {
    "@types/chai": "5.2.3",
    "@types/mocha": "10.0.10",
    "@types/node": "25.4.0",
    "@types/shelljs": "0.10.0",
    "@types/tcp-port-used": "1.0.4",
    "@types/yargs": "17.0.35",
    "chai": "6.2.2",
    "mocha": "11.7.5",
    "ts-node": "10.9.2",
    "ts-node-register": "1.0.0",
    "typescript": "5.9.3"
  }
}
